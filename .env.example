MAINNET_RPC_URL=
DEPLOYER_PRIVATE_KEY=            # S1 deploy + ENS parent owner + gas-drip treasury
PRIVY_APP_ID=
PRIVY_APP_SECRET=               # server wallets
ANTHROPIC_API_KEY=              # agent brain
ENS_PARENT_NAME=bitopiaworld.eth
ENS_PARENT_OWNER_KEY=           # may equal DEPLOYER_PRIVATE_KEY
# Blink deposit on-ramp (USDC). Generate an ECDSA P-256 keypair (see secrets/),
# register the public key at api.blink.cash, then paste the reserved merchantId.
BLINK_MERCHANT_ID=              # merchantId from the Blink merchant application
BLINK_SIGNER_KEY=              # PEM private key (double-quoted, \n-escaped newlines)
VITE_SOCKET_URL=http://localhost:8787
VITE_MAINNET_RPC_URL=
VITE_PRIVY_APP_ID=
VITE_BLINK_MERCHANT_ID=        # optional: same merchantId, warms the hosted flow
# Blink hosted-flow target. 'sandbox' auto-approves merchants (use it to test
# end-to-end without real funds); 'production' is mainnet and needs an
# operator-APPROVED merchant before deposits settle. BLINK_MERCHANT_ID above
# must belong to whichever environment this names.
VITE_BLINK_ENV=production
VITE_BLINK_DEBUG=              # 'true' logs Blink SDK lifecycle events to console
